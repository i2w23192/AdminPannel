-- Resize logic
local resizing = false
local startMouse, startSize, startPos

Handle.MouseButton1Down:Connect(function()
    resizing = true
    startMouse = Vector2.new(Mouse.X, Mouse.Y)
    startSize  = Vector2.new(Win.AbsoluteSize.X, Win.AbsoluteSize.Y)
    startPos   = Vector2.new(Win.AbsolutePosition.X, Win.AbsolutePosition.Y)
end)

local resizeConn
resizeConn = RunService.Heartbeat:Connect(function()
    if not resizing then return end
    local delta = Vector2.new(Mouse.X, Mouse.Y) - startMouse
    local newW  = math.clamp(startSize.X + delta.X, MIN_W, MAX_W)
    local newH  = math.clamp(startSize.Y + delta.Y, MIN_H, MAX_H)

    Win.Size = UDim2.new(0, newW, 0, newH)

    -- Clamp position so window doesn't go off-screen
    local vp = Cam.ViewportSize
    local px = math.clamp(startPos.X, 0, vp.X - newW)
    local py = math.clamp(startPos.Y, 0, vp.Y - newH)
    Win.Position = UDim2.new(0, px, 0, py)

    -- Stretch the log + status bar to fit
    LogScroll.Size    = UDim2.new(1, 0, 0, 50)
    LogScroll.Position = UDim2.new(0, 0, 1, -74)
    StatusBar.Position = UDim2.new(0, 0, 1, -24)

    -- Stretch cmd scroll area to fill available space
    CmdScroll.Size = UDim2.new(1, -101, 1, -130)
    Sidebar.Size   = UDim2.new(0, 100, 1, -130)
end)

UserInputService.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        resizing = false
    end
end)

