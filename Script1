-- Movement
Cmd("fly", {"fl"}, "Movement", "Fly with WASD + Space/Ctrl", function(args, self)
    self.toggle = not self.toggle
    local char = LP.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    if self.toggle then
        hum.PlatformStand = true
        local bv = Instance.new("BodyVelocity")
        bv.Name = "_FlyBV"
        bv.MaxForce = Vector3.new(1e5,1e5,1e5)
        bv.Velocity = Vector3.zero
        bv.Parent = hrp
        local bg = Instance.new("BodyGyro")
        bg.Name = "_FlyBG"
        bg.MaxTorque = Vector3.new(1e5,1e5,1e5)
        bg.D = 100
        bg.Parent = hrp
        State.flyConn = RunService.Heartbeat:Connect(function()
            if not self.toggle then return end
            local spd = 50
            local dir = Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir+=Cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir-=Cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir-=Cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir+=Cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir+=Vector3.yAxis end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir-=Vector3.yAxis end
            bv.Velocity = dir * spd
            bg.CFrame = Cam.CFrame
        end)
        Log("[+] Fly enabled", "ok")
        UpdateStatus("fly","FLY: ON",true)
    else
        hum.PlatformStand = false
        if State.flyConn then State.flyConn:Disconnect() end
        if hrp:FindFirstChild("_FlyBV") then hrp._FlyBV:Destroy() end
        if hrp:FindFirstChild("_FlyBG") then hrp._FlyBG:Destroy() end
        Log("[-] Fly disabled", "warn")
        UpdateStatus("fly","FLY: OFF",false)
    end
end)

