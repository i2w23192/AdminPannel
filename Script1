-- ─── COMMAND LIST RENDERER ───────────────────────────────────────────────────
function RebuildCmdList()
    for _, c in pairs(CmdScroll:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end

    for i, cmd in ipairs(Commands) do
        if cmd.tab == currentTab then
            if currentFilter == "All"
            or (currentFilter == "Toggles" and cmd.toggle)
            or (currentFilter == "Actions" and not cmd.toggle) then

                local row = Button(CmdScroll, "", UDim2.new(1,0,0,26))
                row.LayoutOrder = i
                row.BackgroundColor3 = cmd.toggle and T.ON or T.BG
                Pad(row, 0, 0, 0, 8)

                local nameL = Label(row, cmd.name, UDim2.new(0,110,1,0), UDim2.new(0,0,0,0),
                    cmd.toggle and T.ONText or T.Text, 12, Enum.Font.Code)

                Label(row, cmd.desc, UDim2.new(1,-115,1,0), UDim2.new(0,115,0,0), T.TextDim, 11, Enum.Font.Code)

                local ind = Frame(row, UDim2.new(0,3,1,0), UDim2.new(0,0,0,0),
                    cmd.toggle and T.Accent or T.BG3)

                row.MouseButton1Click:Connect(function()
                    cmd.fn({}, cmd)
                    row.BackgroundColor3 = cmd.toggle and T.ON or T.BG
                    nameL.TextColor3 = cmd.toggle and T.ONText or T.Text
                    ind.BackgroundColor3 = cmd.toggle and T.Accent or T.BG3
                end)

                row.MouseEnter:Connect(function()
                    if not cmd.toggle then row.BackgroundColor3 = Color3.fromRGB(22,22,40) end
                end)
                row.MouseLeave:Connect(function()
                    row.BackgroundColor3 = cmd.toggle and T.ON or T.BG
                end)
            end
        end
    end

    CmdLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        CmdScroll.CanvasSize = UDim2.new(0,0,0, CmdLayout.AbsoluteContentSize.Y)
    end)
end

