-- Visual
Cmd("esp", {}, "Visual", "Player boxes + names + distance", function(args, self)
    self.toggle = not self.toggle
    if self.toggle then
        State.espObjects = {}
        local function makeESP(plr)
            if plr == LP or not plr.Character then return end
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            local box = Instance.new("SelectionBox")
            box.Adornee = plr.Character
            box.Color3 = Color3.fromRGB(255,60,60)
            box.LineThickness = 0.04
            box.SurfaceTransparency = 0.85
            box.SurfaceColor3 = Color3.fromRGB(255,60,60)
            box.Parent = workspace

            local bill = Instance.new("BillboardGui")
            bill.Adornee = hrp
            bill.AlwaysOnTop = true
            bill.Size = UDim2.new(0,100,0,36)
            bill.StudsOffset = Vector3.new(0,3.5,0)
            bill.Parent = workspace

            local nl = Instance.new("TextLabel")
            nl.Size = UDim2.new(1,0,0.55,0)
            nl.BackgroundTransparency = 1
            nl.Text = plr.Name
            nl.TextColor3 = Color3.new(1,1,1)
            nl.TextSize = 13
            nl.Font = Enum.Font.GothamBold
            nl.TextStrokeTransparency = 0
            nl.Parent = bill

            local dl = Instance.new("TextLabel")
            dl.Size = UDim2.new(1,0,0.45,0)
            dl.Position = UDim2.new(0,0,0.55,0)
            dl.BackgroundTransparency = 1
            dl.TextColor3 = Color3.fromRGB(255,200,80)
            dl.TextSize = 11
            dl.Font = Enum.Font.Code
            dl.TextStrokeTransparency = 0
            dl.Parent = bill

            local dc = RunService.Heartbeat:Connect(function()
                local mHRP = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                if mHRP and hrp and hrp.Parent then
                    dl.Text = math.floor((mHRP.Position - hrp.Position).Magnitude) .. "m"
                end
            end)
            table.insert(State.espObjects, {box, bill, dc})
        end
        for _, p in pairs(Players:GetPlayers()) do makeESP(p) end
        State.espAdd = Players.PlayerAdded:Connect(function(p)
            p.CharacterAdded:Connect(function() task.wait(0.5) makeESP(p) end)
        end)
        Log("[+] ESP enabled","ok")
        UpdateStatus("esp","ESP: ON",true)
    else
        for _, t in pairs(State.espObjects or {}) do
            if t[1] and t[1].Parent then t[1]:Destroy() end
            if t[2] and t[2].Parent then t[2]:Destroy() end
            if t[3] then t[3]:Disconnect() end
        end
        State.espObjects = {}
        if State.espAdd then State.espAdd:Disconnect() end
        Log("[-] ESP disabled","warn")
        UpdateStatus("esp","ESP: OFF",false)
    end
end)

