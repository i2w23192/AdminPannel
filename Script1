local function Frame(parent, size, pos, color, trans)
    local f = Instance.new("Frame")
    f.Size = size or UDim2.new(1,0,1,0)
    f.Position = pos or UDim2.new(0,0,0,0)
    f.BackgroundColor3 = color or T.BG
    f.BackgroundTransparency = trans or 0
    f.BorderSizePixel = 0
    f.Parent = parent
    return f
end

local function Label(parent, text, size, pos, color, fontSize, font, align)
    local l = Instance.new("TextLabel")
    l.Size = size or UDim2.new(1,0,1,0)
    l.Position = pos or UDim2.new(0,0,0,0)
    l.BackgroundTransparency = 1
    l.Text = text or ""
    l.TextColor3 = color or T.Text
    l.TextSize = fontSize or 13
    l.Font = font or Enum.Font.Code
    l.TextXAlignment = align or Enum.TextXAlignment.Left
    l.TextTruncate = Enum.TextTruncate.AtEnd
    l.Parent = parent
    return l
end

local function Button(parent, text, size, pos)
    local b = Instance.new("TextButton")
    b.Size = size or UDim2.new(1,0,1,0)
    b.Position = pos or UDim2.new(0,0,0,0)
    b.BackgroundColor3 = T.BG
    b.BorderSizePixel = 0
    b.Text = text or ""
    b.TextColor3 = T.Text
    b.TextSize = 13
    b.Font = Enum.Font.Code
    b.TextXAlignment = Enum.TextXAlignment.Left
    b.AutoButtonColor = false
    b.Parent = parent
    return b
end

local function Input(parent, placeholder, size, pos)
    local i = Instance.new("TextBox")
    i.Size = size or UDim2.new(1,0,1,0)
    i.Position = pos or UDim2.new(0,0,0,0)
    i.BackgroundTransparency = 1
    i.TextColor3 = T.Text
    i.PlaceholderColor3 = T.TextDim
    i.PlaceholderText = placeholder or ""
    i.Text = ""
    i.TextSize = 13
    i.Font = Enum.Font.Code
    i.ClearTextOnFocus = false
    i.BorderSizePixel = 0
    i.TextXAlignment = Enum.TextXAlignment.Left
    i.Parent = parent
    return i
end

local function Divider(parent, yOff)
    local d = Frame(parent, UDim2.new(1,0,0,1), UDim2.new(0,0,0,yOff), T.Border)
    return d
end

local function Corner(parent, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 3)
    c.Parent = parent
    return c
end

local function Pad(parent, top, right, bottom, left)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top or 4)
    p.PaddingRight  = UDim.new(0, right or 4)
    p.PaddingBottom = UDim.new(0, bottom or 4)
    p.PaddingLeft   = UDim.new(0, left or 4)
    p.Parent = parent
    return p
end

